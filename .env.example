# Urlveil Environment Variables
# Copy this file to .env.local and fill in the values
# NEVER commit .env.local to version control

# App
NEXT_PUBLIC_APP_URL=https://urlveil.id

# ── Cek Link (URL) ─────────────────────────────────
# GOOGLE_SAFE_BROWSING_API_KEY=
# URLSCAN_API_KEY=

# ── Cek File / APK ───────────────────────────────
# VirusTotal — daftar gratis di https://www.virustotal.com/gui/join-us
# API publik gratis: ~4 request/menit, ~500 request/hari.
# VIRUSTOTAL_API_KEY=

# URLhaus — daftar gratis di https://auth.abuse.ch/ (opsional, tapi disarankan
# karena API URLhaus kemungkinan mensyaratkan Auth-Key untuk akses stabil)
# URLHAUS_AUTH_KEY=

# Analytics (if needed)
# NEXT_PUBLIC_GA_ID=
