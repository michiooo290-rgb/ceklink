# Urlveil Environment Variables
# Copy this file to .env.local and fill in the values
# NEVER commit .env.local to version control

# App
NEXT_PUBLIC_APP_URL=https://urlveil.id

# ── Cek Link (URL) ─────────────────────────────────
# GOOGLE_SAFE_BROWSING_API_KEY=
# URLSCAN_API_KEY=

# ── Cek File / APK ───────────────────────────────
# VirusTotal — daftar gratis di https://www.virustotal.com/gui/join-us
# API publik gratis: ~4 request/menit, ~500 request/hari.
# Juga dipakai di /api/domain-intel untuk reputasi domain.
# VIRUSTOTAL_API_KEY=

# URLhaus — daftar gratis di https://auth.abuse.ch/ (opsional, tapi disarankan
# karena API URLhaus kemungkinan mensyaratkan Auth-Key untuk akses stabil)
# URLHAUS_AUTH_KEY=

# ── Domain Intel (IP reputation, WHOIS, SSL) ─────
# AbuseIPDB — daftar gratis di https://www.abuseipdb.com/register
# API publik gratis: 1000 request/hari.
# ABUSEIPDB_API_KEY=
# WHOIS/RDAP tidak butuh API key (pakai rdap.org, standar publik IANA)
# SSL/TLS check juga tidak butuh API key (native Node tls)

# Analytics (if needed)
# NEXT_PUBLIC_GA_ID=
